{
  "name": "robosurvivor-2026-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:artifacts": "tsx src/generateArtifacts.ts",
    "generate:stm32": "tsx src/generateStm32Tables.ts",
    "video:install": "npm --prefix video install",
    "video:studio": "npm --prefix video run studio",
    "video:render": "npm --prefix video run render",
    "video:test": "npm --prefix video run test",
    "slides:install": "npm --prefix slides install",
    "slides:dev": "npm --prefix slides run dev",
    "slides:build": "npm --prefix slides run build",
    "slides:test": "npm --prefix slides run test"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/seedrandom": "^3.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "seedrandom": "^3.0.5"
  }
}
